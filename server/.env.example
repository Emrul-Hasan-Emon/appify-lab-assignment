PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/appify_lab

# Deploy-only overrides (leave unset for local dev):
# DB_SYNCHRONIZE=true      # force schema auto-sync even when NODE_ENV=production
# DB_SSL=true              # required by some managed Postgres providers over public connections
# CORS_ORIGIN=https://your-app.vercel.app   # comma-separated allowed origins; unset = allow all

JWT_SECRET=
JWT_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=appify-lab
